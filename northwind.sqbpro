 value="140"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT COUNT(*) AS Productos_Totales_pqsixdxdxd FROM Products

SELECT AVG(UnitPrice), MAX (UnitPrice) AS Precio_maximomaximoalaaxdxdxd FROM Products;

SELECT SUM(UnitPrice) AS Suma_Precios FROM Products WHERE CategoryID = 2;

SELECT ProductName, UnitPrice as Caro_we FROM Products ORDER BY UnitPrice DESC LIMIT 5;

SELECT CompanyName, Country, City FROM Customers WHERE Country = 'Germany' ORDER BY CompanyName ASC;

SELECT Country, COUNT(CustomerID) AS Clientes_Total FROM Customers GROUP BY Country ORDER BY Clientes_TOTAL DESC;

SELECT CategoryID, AVG(UnitPrice) AS P_P_P_P From Products GROUP BY CategoryID;

</sql><current_tab id="0"/></tab_sql></sqlb_project>
